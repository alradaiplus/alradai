# ----------------------------------------------------------------------------
# Notes Canvas — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
# ----------------------------------------------------------------------------

# Public site URL (used for OpenRouter referer header + auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (AI) --------------------------------------------------------
# Up to three keys are rotated automatically on rate-limit / quota errors.
# Get keys at https://openrouter.ai/keys
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=

# Model routing (any OpenRouter model id). Primary is tried first, fallback on capacity errors.
OPENROUTER_MODEL_PRIMARY=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_FALLBACK=anthropic/claude-3.5-haiku
